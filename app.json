{
  "expo": {
    "name": "QRBuilder",
    "slug": "QRBuilder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "QR kodlarını galeriye kaydetmek ve logo eklemek için galeri erişimi gerekiyor.",
        "NSPhotoLibraryAddUsageDescription": "QR kodlarını galeriye kaydetmek için erişim gerekiyor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "QR kodlarını galeriye kaydetmek için galeri erişimi gerekiyor.",
          "savePhotosPermission": "QR kodlarını galeriye kaydetmek için erişim gerekiyor.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QR koduna logo eklemek için galeri erişimi gerekiyor."
        }
      ],
      "expo-sharing"
    ]
  }
}
